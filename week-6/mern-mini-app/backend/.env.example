# Backend environment variables example
# Copy this to .env and fill in your values

# Server port (Render will override this in production)
PORT=5000

# MongoDB Atlas connection string
DB_URL=mongodb+srv://username:password@cluster.mongodb.net/databasename?appName=Cluster0

# Environment type
NODE_ENV=production

# Frontend URL for CORS (update after deploying frontend on Vercel)
# Example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
